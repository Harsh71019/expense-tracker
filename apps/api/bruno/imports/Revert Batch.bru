meta {
  name: Revert Batch
  type: http
  seq: 7
}

post {
  url: {{baseUrl}}/v1/imports/{{importBatchId}}/revert
  body: none
}

headers {
  Idempotency-Key: {{$randomUUID}}
}

docs {
  Reverses every transaction that Commit Batch posted for {{importBatchId}},
  via compensating entries — never deletes them.
}
