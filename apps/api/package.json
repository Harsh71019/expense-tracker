{
  "name": "@vyaya/api",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "gen:openapi": "tsx scripts/generate-openapi.ts",
    "dev": "tsc -p tsconfig.json && concurrently -k -n tsc,node -c blue,green \"tsc --watch -p tsconfig.json --preserveWatchOutput\" \"node --env-file=../../.env --env-file-if-exists=../../.env.development.local --watch --watch-path=dist --watch-path=../../packages/shared/dist dist/main.js\"",
    "lint": "eslint --config ../../eslint.config.mjs --no-warn-ignored --max-warnings=0 src/ test/",
    "typecheck": "tsc --noEmit -p tsconfig.test.json",
    "test": "vitest run --passWithNoTests",
    "test:integration": "vitest run --passWithNoTests --config vitest.integration.config.ts",
    "test:e2e": "vitest run --passWithNoTests --config vitest.e2e.config.ts",
    "migrate": "migrate-mongo up -f ../../migrate-mongo-config.cjs",
    "migrate:status": "migrate-mongo status -f ../../migrate-mongo-config.cjs",
    "drizzle:generate": "drizzle-kit generate",
    "drizzle:migrate": "drizzle-kit migrate",
    "drizzle:check": "drizzle-kit check"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^8.5.0",
    "@better-auth/mongo-adapter": "latest",
    "@bull-board/api": "latest",
    "@bull-board/express": "latest",
    "@nestjs/common": "latest",
    "@nestjs/config": "latest",
    "@nestjs/core": "latest",
    "@nestjs/mongoose": "latest",
    "@nestjs/platform-express": "latest",
    "@nestjs/schedule": "latest",
    "@vyaya/shared": "workspace:*",
    "better-auth": "latest",
    "bullmq": "latest",
    "cookie-parser": "latest",
    "csv-parse": "latest",
    "drizzle-orm": "^0.45.2",
    "express": "latest",
    "helmet": "latest",
    "ioredis": "latest",
    "migrate-mongo": "latest",
    "mongoose": "latest",
    "nestjs-pino": "latest",
    "pg": "^8.22.0",
    "pino": "latest",
    "reflect-metadata": "latest",
    "rxjs": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@swc/core": "1.15.43",
    "@testcontainers/postgresql": "^12.0.4",
    "@types/cookie-parser": "latest",
    "@types/express": "latest",
    "@types/pg": "^8.20.0",
    "@vitest/coverage-v8": "^4.1.10",
    "@vyaya/config": "workspace:*",
    "concurrently": "latest",
    "drizzle-kit": "^0.31.10",
    "mongodb-memory-server": "latest",
    "testcontainers": "^12.0.4",
    "unplugin-swc": "1.5.9"
  }
}
