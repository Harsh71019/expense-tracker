{
  "name": "@vyaya/web",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "next build",
    "dev": "next dev",
    "dev:mock": "NEXT_PUBLIC_MOCK_API=1 next dev",
    "check:circular": "madge --circular --extensions ts,tsx --ts-config tsconfig.json src",
    "lint": "eslint --config eslint.config.mjs --no-warn-ignored --max-warnings=0 src/ e2e/ tests/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@sentry/nextjs": "latest",
    "@tanstack/react-query": "^5.101.2",
    "@vyaya/shared": "workspace:*",
    "better-auth": "latest",
    "next": "latest",
    "openapi-fetch": "^0.17.0",
    "react": "latest",
    "react-dom": "latest",
    "react-hook-form": "^7.81.0",
    "server-only": "^0.0.1",
    "sonner": "^2.0.7",
    "zod": "latest"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "latest",
    "@tailwindcss/postcss": "latest",
    "@testing-library/jest-dom": "latest",
    "@testing-library/react": "latest",
    "@testing-library/user-event": "latest",
    "@vitejs/plugin-react": "5.2.0",
    "@vyaya/config": "workspace:*",
    "jsdom": "latest",
    "msw": "^2.15.0",
    "openapi-msw": "^2.0.0",
    "tailwindcss": "latest",
    "typescript": "beta"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
