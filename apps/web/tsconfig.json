{
  "extends": "@treasury-ops/config/tsconfig/base.json",
  "compilerOptions": {
    "composite": true,
    "jsx": "react-jsx",
    "plugins": [{ "name": "next" }],
    "allowJs": false,
    "incremental": true,
    "noEmit": true,
    "isolatedModules": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["next-env.d.ts", ".next/types/**/*.ts", "**/*.ts", "**/*.tsx"],
  "exclude": ["node_modules"]
}
