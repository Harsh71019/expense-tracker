# /opt/apps/vyaya/.env  (server only — chmod 600, never committed)

NODE_ENV=production
GIT_SHA=development
LOG_LEVEL=info
SERVICE_ROLE=api

# --- Ports (internal; only nginx :3006 is exposed on the host) ---
API_PORT=4000
WEB_PORT=3000

# --- MongoDB Atlas ---
# Use the staging database locally; production uses the vyaya database.
# Each environment must have a separately scoped Atlas database user.
MONGODB_URI=mongodb+srv://vyaya-stg-app:<password>@<atlas-cluster>/vyaya-stg?retryWrites=true&w=majority

# --- Redis (compose service name) ---
# Shared Redis infrastructure. Use a distinct database number and a URL-encoded password.
REDIS_URL=redis://:replace-with-encoded-password@redis-host:6379/2

# --- Better Auth ---
BETTER_AUTH_SECRET=<openssl rand -base64 32>
BETTER_AUTH_URL=http://192.168.0.226:3006
# HTTP on LAN -> secure cookies must be off or the browser drops them
# (same reason as COOKIE_SECURE=false in Taskflow). Flip to true behind NPMplus/TLS.
AUTH_COOKIE_SECURE=false
TRUSTED_ORIGINS=http://192.168.0.226:3006

# --- App ---
APP_TIMEZONE=Asia/Kolkata
DISABLE_SIGNUP=false        # set true after creating your account

# --- Notifications ---
NTFY_URL=
NTFY_TOPIC=vyaya
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Observability (optional) ---
GLITCHTIP_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
