{
  "name": "vyaya",
  "private": true,
  "engines": {
    "node": "24.18.x"
  },
  "packageManager": "pnpm@10.28.1",
  "scripts": {
    "build": "pnpm --filter @vyaya/shared build && pnpm --filter @vyaya/api build && pnpm --filter @vyaya/web build",
    "dev": "pnpm --filter @vyaya/shared build && pnpm --parallel --filter @vyaya/shared --filter @vyaya/api --filter @vyaya/web dev",
    "lint": "pnpm --recursive lint",
    "typecheck": "pnpm --recursive typecheck",
    "test": "pnpm --recursive test",
    "test:integration": "pnpm --filter @vyaya/api test:integration",
    "migrate": "pnpm --filter @vyaya/api migrate",
    "verify:migrations": "tsx scripts/verify-migrations.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky",
    "lint-staged": "lint-staged"
  },
  "devDependencies": {
    "@commitlint/cli": "latest",
    "@commitlint/config-conventional": "latest",
    "@eslint/js": "latest",
    "@nestjs/cli": "latest",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@typescript/typescript6": "latest",
    "eslint": "latest",
    "eslint-config-next": "latest",
    "husky": "latest",
    "lint-staged": "latest",
    "mongodb-memory-server": "latest",
    "prettier": "latest",
    "tsx": "latest",
    "typescript": "beta",
    "typescript-eslint": "latest",
    "vitest": "latest",
    "zod": "latest"
  },
  "pnpm": {
    "overrides": {
      "@typescript-eslint/typescript-estree>typescript": "npm:@typescript/typescript6@*"
    }
  }
}
