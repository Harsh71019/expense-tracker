{
  "name": "treasury-ops",
  "private": true,
  "engines": {
    "node": "24.18.x"
  },
  "packageManager": "pnpm@10.28.1",
  "scripts": {
    "build": "pnpm --filter @treasury-ops/shared build && pnpm --filter @treasury-ops/api build && pnpm --filter @treasury-ops/web build",
    "dev": "pnpm --filter @treasury-ops/shared build && pnpm --parallel --filter @treasury-ops/shared --filter @treasury-ops/api --filter @treasury-ops/web dev",
    "gen:client": "pnpm --filter @treasury-ops/api gen:openapi && openapi-typescript apps/api/openapi.json -o apps/web/src/lib/api/generated/schema.d.ts",
    "lint": "pnpm --filter @treasury-ops/shared build && pnpm --recursive lint",
    "typecheck": "pnpm --filter @treasury-ops/shared build && pnpm --recursive typecheck",
    "test": "pnpm --filter @treasury-ops/shared build && pnpm --recursive test",
    "test:integration": "pnpm --filter @treasury-ops/shared build && pnpm --filter @treasury-ops/api test:integration",
    "test:e2e": "pnpm --filter @treasury-ops/shared build && pnpm --filter @treasury-ops/api test:e2e",
    "migrate": "pnpm --filter @treasury-ops/api migrate",
    "verify:migrations": "tsx scripts/verify-migrations.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky",
    "lint-staged": "lint-staged"
  },
  "devDependencies": {
    "@commitlint/cli": "latest",
    "@commitlint/config-conventional": "latest",
    "@eslint/js": "^9.39.5",
    "@nestjs/cli": "latest",
    "@tanstack/eslint-plugin-query": "^5.101.2",
    "@testcontainers/postgresql": "^12.0.4",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@typescript/typescript6": "latest",
    "eslint": "^9.39.5",
    "eslint-config-next": "latest",
    "husky": "latest",
    "lint-staged": "latest",
    "madge": "latest",
    "openapi-typescript": "^7.13.0",
    "prettier": "latest",
    "tsx": "latest",
    "typescript": "6.0.0-beta",
    "typescript-eslint": "latest",
    "vite": "7.3.6",
    "vitest": "4.1.10",
    "zod": "latest"
  },
  "pnpm": {
    "overrides": {
      "@typescript-eslint/typescript-estree>typescript": "npm:@typescript/typescript6@*",
      "vite": "7.3.6"
    },
    "onlyBuiltDependencies": [
      "@swc/core"
    ]
  }
}
